els.mean(), all_pixels.std()\n\n# Plot\nfig = px.histogram(\n    x=plot_pixels,\n    nbins=100,\n    opacity=0.8,\n    color_discrete_sequence=['#add8e6'],\n    title=f\"Pixel Value Distribution (Mean={mean:.4f}, Std={std:.4f})\"\n)\n\nfig.add_vline(x=mean, line_width=2, line_dash=\"dash\", line_color=\"red\", annotation_text=f\"Mean={mean:.3f}\")\n\nfig.update_layout(\n    xaxis_title='Pixel value (scaled 0–1)',\n    yaxis_title='Frequency',\n    bargap=0.05,\n    template='simple_white'\n)\n\nfig.show()","metadata":{"_uuid":"14aec2d5-a239-404d-b81f-2f62683c3067","_cell_guid":"199ea83c-7c43-43d5-a04c-99bc18f3dfe7","trusted":true,"collapsed":false,"execution":{"iopub.status.busy":"2026-06-21T12:12:55.413029Z","iopub.execute_input":"2026-06-21T12:12:55.413736Z","iopub.status.idle":"2026-06-21T12:13:10.888168Z","shell.execute_reply.started":"2026-06-21T12:12:55.413707Z","shell.execute_reply":"2026-06-21T12:13:10.887219Z"},"jupyter":{"outputs_hidden":false}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Define Yawn-Eye Dataset Path\nyawn_eye_base = \"/kaggle/input/yawn-eye-dataset-new/dataset_new/train\"\n# Print available class names\nprint(\"Available class folders:\", os.listdir(yawn_eye_base))\n\n# Class Mapping for Yawn-Eye (adjusted based on actual folder names)\n# 1 = Drowsy (yawning or eyes closed), 0 = Awake (not yawning and eyes open)\nyawn_eye_map = {\n    \"Closed\": 1,\n    \"yawn\": 1,\n    \"Open\": 0,\n    \"no_yawn\": 0\n}","metadata":{"_uuid":"1494c84c-f01a-4114-9d6e-5937b1866b7e","_cell_guid":"bb4dc4f5-a95b-4e3e-b116-3f04337e5561","trusted":true,"collapsed":false,"execution":{"iopub.status.busy":"2026-06-21T12:13:36.422725Z","iopub.execute_input":"2026-06-21T12:13:36.423432Z","iopub.status.idle":"2026-06-21T12:13:36.432197Z","shell.execute_reply.started":"2026-06-21T12:13:36.423404Z","shell.execute_reply":"2026-06-21T12:13:36.431475Z"},"jupyter":{"outputs_hidden":false}},"outputs":[],"execution_count":null},{"cell_type":"code",