uptitle(title, fontsize=16)\n    plt.tight_layout()\n    plt.show()\n\n# Show train samples\nplot_samples(df_train, title=\"Sample Images per Label - Train Set\")\n\n# Show test samples\nplot_samples(df_test, title=\"Sample Images per Label - Test Set\")","metadata":{"_uuid":"3ee6f5d6-5b2d-4aba-a3ae-3524be645f18","_cell_guid":"ea9a46e6-070c-41eb-81f1-269db146c1bf","trusted":true,"collapsed":false,"execution":{"iopub.status.busy":"2026-05-25T09:17:31.919977Z","iopub.execute_input":"2026-05-25T09:17:31.920787Z","iopub.status.idle":"2026-05-25T09:17:35.004168Z","shell.execute_reply.started":"2026-05-25T09:17:31.920763Z","shell.execute_reply":"2026-05-25T09:17:35.003242Z"},"jupyter":{"outputs_hidden":false}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Dataset DataFrame assumed: df_train, df_test with ['image_path','label']\n# Example: you already have df_train and df_test after split (label: 0,1,2)\nfrom tensorflow.keras.utils import to_categorical\n# Function: preprocess image\ndef preprocess(path, size=(96,96)):\n    try:\n        return np.array(Image.open(path).convert(\"RGB\").resize(size)) / 255.0\n    except:\n        return None\n\n# Load and preprocess train data\nX_train, y_train = zip(*[(img, lbl) for path,lbl in df_train.values if (img:=preprocess(path)) is not None])\nX_train, y_train = np.array(X_train), np.array(y_train)\n\n# One-hot encode labels\ny_train_cat = to_categorical(y_train, num_classes=3)\n\n# Load and preprocess test data\nX_test, y_test = zip(*[(img, lbl) for path,lbl in df_test.values if (img:=preprocess(path)) is not None])\nX_test, y_test = np.array(X_test), np.array(y_test)\ny_test_cat = to_categorical(y_test, num_classes=3)\n\nprint(f\"Train samples: {len(X_train)} | Test samples: {len(X_test)}\")\n\n# Function: build model\ndef build_model(type=\"vgg16\"):\n    input_tensor = Input(shape=(96,96,3))\n    \n    if type in [\"vgg16\",\"vgg19\",\"inception\",\"efficientnet\"]:\n        base_cls = {\"vgg16\": VGG16, \"vgg19\": VGG19, \"inception\": InceptionV3, \"efficientnet\": EfficientNetB0}[type]\n        base = base_cls(include_top=False, weights='imagenet', input_tensor=input_tensor)\n        for l in base.layers:\n            l.trainable = False\n        x = GlobalAveragePooling2D()(base.output)\n    else:\n        x = Conv2D(32,3,activation='relu')(input_tensor)\n        x = MaxPooling2D()(x)\n        x = Conv2D(64,3,activation='relu')(x)\n        x = GlobalAveragePooling2D()(x)\n        \n    x = Dense(64 if type!=\"shufflenet\" else 32, activation='relu')(x)\n    x = Dropout(0.3)(x)\n    out = Dense(3, activation='softmax')(x)\n    \n    model = Model(inputs=input_tensor, outputs=out)\n    model.compile(optimizer='adam', loss='categorical_crossentropy', metrics=['accuracy'])\n    return model\n\n# Build and train models\nmodels = {name: build_model(name) for name in [\"vgg16\",\"vgg19\",\"inception\",\"efficientnet\",\"squeezenet\",\"shufflenet\"]}\nhistory = {}\n\nfor name, model in models.items():\n    print(f\"\\nTraining: {name}\")\n    hist = model.fit(X_train, y_train_cat, epochs=15, batch_size=32, validation_split=0.1, verbose=1)\n    history[name] = hist\n\nprint(\"\\nAll models trained.\")\n\n# Evaluate each model\nfor name, model in models.items():\n    print(f\"\\nEvaluation: {name}\")\n    preds_probs = model.predict(X_test)\n    preds = np.argmax(preds_probs, axis=1)\n    \n    print(classification_report(y_test, preds, target_names=['Safe Driving','Using Phone','Turning']))\n    cm = confusion_matrix(y_test, preds)\n    print(\"Confusion matrix:\\n\", cm)","metadata":{"_uuid":"a3072bb8-afc5-4d7b-92d1-62744388ef95","_cell_guid":"5cefffa4-226f-46e2-a9e1-7ea0be539e7c","trusted":true,"collapsed":false,"execution":{"iopub.status.busy":"2026-05-25T09:17:40.50713Z","iopub.execute_input":"2026-05-25T09:17:40.507385Z","iopub.status.idle":"2026-05-25T09:30:02.272836Z","shell.execute_reply.started":"2026-05-25T09:17:40.507368Z","shell.execute_reply":"2026-05-25T09:30:02.272054Z"},"jupyter":{"outputs_hidden":false}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score, classification_report, confusion_matrix\n\nresults = []\ny_preds = {}\n\nprint(\"\\nEvaluating each model on test set...\")\n\nfor name, model in models.items():\n    print(f\"\\nEvaluation: {name}\")\n    \n    # Predict on test set\n    preds_probs = model.predict(X_test)\n    preds = np.argmax(preds_probs, axis=1)\n    y_preds[name] = preds\n    \n    # Calculate metrics\n    acc  = accuracy_score(y_test, preds)\n    prec = precision_score(y_test, preds, average='weighted')\n    rec  = recall_score(y_test, preds, average='weighted')\n    f1   = f1_score(y_test, preds, average='weighted')\n    results.append([name, acc, prec, rec, f1])\n    \n    print(\"\\nClassification Report:\")\n    print(classification_report(y_test, preds, target_names=['Safe Driving','Using Phone','Turning']))\n    \n    # Plot Confusion Matrix\n    plt.figure(figsize=(4,4))\n    sns.heatmap(confusion_matrix(y_test, preds), annot=True, fmt='d', cmap='Blues',\n                xticklabels=['Safe Driving','Using Phone','Turning'],\n                yticklabels=['Safe Driving','Using Phone','Turning'])\n    plt.title(f\"Confusion Matrix - {name}\")\n    plt.xlabel(\"Predicted\")\n    plt.ylabel(\"Actual\")\n    plt.show()\n    \n    # Plot Training Curves (train & val if available)\n    hist = history[name].history\n    plt.figure(figsize=(10,4))\n    \n    plt.subplot(1,2,1)\n    plt.plot(hist['accuracy'], label='Train Accuracy')\n    if 'val_accuracy' in hist:\n        plt.plot(hist['val_accuracy'], label='Val Accuracy')\n    plt.title(f\"Accuracy - {name}\")\n    plt.xlabel(\"Epoch\")\n    plt.ylabel(\"Accuracy\")\n    plt.legend()\n    \n    plt.subplot(1,2,2)\n    plt.plot(hist['loss'], label='Train Loss')\n    if 'val_loss' in hist:\n        plt.plot(hist['val_loss'], label='Val Loss')\n