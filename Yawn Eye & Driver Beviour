path)\n    img_input = np.expand_dims(img_arr, axis=0)\n\n    # Predict drowsy\n    drowsy_pred = drowsy_model.predict(img_input, verbose=0)[0]\n    if len(drowsy_pred)==1:\n        drowsy_prob = float(drowsy_pred[0])\n        drowsy_class = int(drowsy_prob > 0.5)\n    else:\n        drowsy_class = np.argmax(drowsy_pred)\n        drowsy_prob  = drowsy_pred[drowsy_class]\n    if drowsy_class not in drowsy_labels:\n        drowsy_class = 1 if drowsy_prob > 0.5 else 0\n\n    # Predict behavior\n    behavior_pred = behavior_model.predict(img_input, verbose=0)[0]\n    behavior_class = int(np.argmax(behavior_pred))\n    behavior_prob  = behavior_pred[behavior_class]\n    if behavior_class not in behavior_labels:\n        behavior_class = 0\n\n    # Final decision\n    if drowsy_class==1 and behavior_class==1:\n        final = \"Highly Distraction\"\n    elif drowsy_class==1 and behavior_class==2:\n        final = \"Dangerous\"\n    elif drowsy_class==0 and behavior_class==0:\n        final = \"Normal\"\n    else:\n        final = \"Other\"\n\n    # Save if final is target\n    if final in final_classes and final_classes[final] is None:\n        final_classes[final] = {\n            \"img_path\": img_path,\n            \"drowsy_class\": drowsy_class,\n            \"drowsy_prob\": drowsy_prob,\n            \"behavior_class\": behavior_class,\n            \"behavior_prob\": behavior_prob,\n            \"final\": final\n        }\n\nprint(f\"\\nFound: {sum(x is not None for x in final_classes.values())} of 3 target classes after {tries} tries.\")\n\n# Plot\nplt.figure(figsize=(12,4))\nidx = 0\nfor final_label, info in final_classes.items():\n    if info is not None:\n        idx +=1\n        plt.subplot(1, 3, idx)\n        plt.imshow(Image.open(info[\"img_path\"]))\n        plt.axis('off')\n        plt.title(\n            f\"Drowsy: {drowsy_labels[info['drowsy_class']]} ({info['drowsy_prob']:.2f})\\n\"\n            f\"Behavior: {behavior_labels[info['behavior_class']]} ({info